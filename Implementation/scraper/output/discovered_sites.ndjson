{"url": "https://www.uab.edu/research/home/about/senior-leadership/gina-hedberg", "label": "highly_relevant", "title": "Gina Hedberg | Office of Research", "source_query": "site:uab.edu Vice President email", "scraped_status": "ok", "scraped_at": "2025-12-16T04:32:52+0000", "llm_payload": {"name": "Gina Hedberg", "category": "Associate Vice President for Research; Executive Director of Sponsored Programs", "description": "Hedberg is responsible for leading the Office of Sponsored Programs (OSP) as partner to UAB’s faculty and staff in their efforts to secure and fulfill extramural support and conduct cutting-edge research and scholarship. Under her leadership, OSP performs pre-award and non-financial post-award administration, including review of grant proposals for compliance, and negotiation of contracts for federal, industry, state/local and non-profit entities. She interacts with schools and units across the entire university to facilitate efficient grants and contract processing. Additionally, she provides advice and counsel to the vice president for Research and serve as a member of the UAB Office of Research senior staff.", "website": "https://www.uab.edu", "contact_email": null, "phone": "(205) 934-5266", "address": "Administration Building, Suite 720, 701 20th Street South", "city": "Birmingham", "country": "USA", "social_links": [], "tags": ["Associate Vice President", "Research", "Sponsored Programs", "UAB"], "price": null, "price_numeric": 0, "opening_hours": null, "extra": null, "source_urls": ["https://www.uab.edu/research/home/about/senior-leadership/gina-hedberg", "https://www.uab.edu/research/home/about/senior-leadership"]}, "vertical": null, "vertical_reason": null, "vertical_score_delta": null}
