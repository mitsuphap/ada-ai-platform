{"url": "https://www.uab.edu/research/home/about/senior-leadership/christopher-brown", "label": "highly_relevant", "title": "Christopher S. Brown, Ph.D. | Office of Research", "source_query": "site:uab.edu Vice President email", "scraped_status": "ok", "scraped_at": "2025-12-16T04:32:51+0000", "llm_payload": {"name": "Christopher S. Brown, Ph.D.", "category": "Vice President for Research", "description": "Christopher S. Brown is the Vice President for Research at UAB and a tenured professor in the Department of Biology. He previously served as Associate Vice Chancellor for Research Development at NCSU and Vice President for Research at the University of North Carolina System. His research focused on the effects of spaceflight on plant growth. In his current position, he works to broaden and enhance UAB’s research portfolio and strengthen research support operations.", "website": "https://www.uab.edu", "contact_email": null, "phone": "(205) 934-1294", "address": "Administration Building, Suite 720, 701 20th Street South, Birmingham, AL 35233", "city": "Birmingham", "country": "USA", "social_links": [], "tags": ["Vice President", "Research", "UAB"], "source_urls": ["https://www.uab.edu/research/home/about/senior-leadership/christopher-brown", "https://www.uab.edu/research/home/about/senior-leadership"]}, "vertical": null, "vertical_reason": null, "vertical_score_delta": null}
